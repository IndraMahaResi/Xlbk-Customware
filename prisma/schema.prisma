// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  role      Role     @default(USER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Product {
  id          String      @id @default(cuid())
  name        String
  category    Category
  description String?
  price       Float
  image       String
  stock       Boolean     @default(true)
  minOrder    String?     @default("Bisa Satuan")
  rating      Float?      @default(5.0)
  sold        String?     @default("0")
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  orders      OrderItem[]
}

model Order {
  id             String               @id @default(cuid())
  invoiceNumber  String               @unique
  customerName   String
  customerEmail  String
  customerPhone  String
  address        String?
  countryOrigin  String               @default("Indonesia") // 🟢 FITUR 5: Filter negara (Indonesia/Luar Negeri)
  designFile     String?
  designNotes    String?
  notes          String?
  subtotal       Float
  shippingFee    Float                @default(0)
  taxFee         Float                @default(0) // 🟢 FITUR 4: Untuk PPN
  total          Float
  status         OrderStatus          @default(PENDING)
  paymentMethod  PaymentMethod
  paymentStatus  PaymentStatus        @default(UNPAID)
  paymentDetails Json?
  paymentProof   String?
  paidAt         DateTime?
  expiredAt      DateTime
  receiptNumber  String?              // 🟢 FITUR 3: Nomor Resi Pengiriman
  isWaNotified   Boolean              @default(false) // 🟢 FITUR 2 & 3: Status notif WA terkirim
  paymentType    PaymentType          @default(FULL) // 🟢 BARU: Mencatat tipe (FULL / DP)
  amountPaid     Float                @default(0)    // 🟢 BARU: Uang yang sudah masuk
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
  items          OrderItem[]
  transactions   PaymentTransaction[]
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  productId String
  quantity  Int
  price     Float
  notes     String?
  order     Order   @relation(fields: [orderId], references: [id])
  product   Product @relation(fields: [productId], references: [id])
}

// 🟢 FITUR 1: Tabel Setting (Tema, Gmaps, WA Owner)
model Setting {
  id         String   @id @default(cuid())
  themeColor String   @default("blue")
  gmapsUrl   String?  @db.Text
  waNumber   String   @default("6281283433771") // Default WA Owner
  updatedAt  DateTime @updatedAt
}

// 🟢 FITUR 6: Tabel Portofolio (Hasil Produk Jadi)
model Portfolio {
  id          String   @id @default(cuid())
  title       String
  description String?
  imageUrl    String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

enum Role {
  OWNER
  ADMIN
  USER
}

enum Category {
  SOUVENIR
  MUG
  TUMBLER
  TOTEBAG
  KAOS
  BAJU
  LAINNYA
}

enum OrderStatus {
  PENDING
  PROCESSING
  SHIPPED       // 🟢 FITUR 3: Status baru saat barang dikirim
  COMPLETED
  CANCELLED
  NEED_VERIFICATION // 🟢 FITUR 5: Untuk order luar negeri
}

enum PaymentMethod {
  BANK_TRANSFER
  QRIS
  BTC
  USDT
}

enum PaymentStatus {
  UNPAID
  PENDING
  PAID
  VERIFIED
  EXPIRED
  FAILED
}

model PaymentTransaction {
  id             String        @id @default(cuid())
  orderId        String
  order          Order         @relation(fields: [orderId], references: [id])
  amount         Float
  method         PaymentMethod
  status         PaymentStatus @default(PENDING)
  transactionId  String?
  qrCode         String?
  qrString       String?
  walletAddress  String?
  cryptoAmount   Float?
  cryptoCurrency String?
  bankName       String?
  bankAccount    String?
  accountName    String?
  expiresAt      DateTime
  paidAt         DateTime?
  paymentProof   String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
}

model Testimonial {
  id          String   @id @default(cuid())
  name        String
  email       String?
  role        String?
  message     String
  rating      Int      @default(5)
  image       String?
  productName String?
  isApproved  Boolean  @default(false)
  isFeatured  Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

enum PaymentType {
  FULL
  DP
}

// Model untuk menyimpan pengaturan dinamis website
model StoreSettings {
  id              String   @id @default(cuid())
  
  // Kontak Dasar & Lokasi
  whatsapp        String?  
  email           String?  
  address         String?  @db.Text
  gmapsEmbed      String?  @db.Text 
  
  // Pembayaran: QRIS & Crypto (Statis, biasanya hanya 1)
  qrisImage       String?  
  cryptoBtc       String?  
  cryptoUsdt      String?  

  // 🔥 FITUR BARU: Data Dinamis (Disimpan dalam format JSON Array)
  socials         Json?    // Contoh: [{ name: "Instagram", url: "..." }]
  marketplaces    Json?    // Contoh: [{ name: "Shopee", url: "..." }]
  banks           Json?    // Contoh: [{ bank: "BCA", number: "123", owner: "PT XLBK" }]

  promoActive     Boolean  @default(false)
  promoMessage    String?
  promoLink       String?
  promoButtonText String?

  updatedAt       DateTime @updatedAt
}
// 🟢 FITUR 6: Tabel Hasil Karya (Produk Jadi)
model HasilKarya {
  id          String   @id @default(cuid())
  title       String
  description String?
  imageUrl    String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
// 🟢 FITUR BARU: Tabel Promo & Event
model PromoEvent {
  id          String   @id @default(cuid())
  title       String
  description String?
  imageUrl    String
  badge       String?  @default("PROMO") // Contoh: "DISKON 50%", "EVENT BARU"
  createdAt   DateTime @default(now())
}